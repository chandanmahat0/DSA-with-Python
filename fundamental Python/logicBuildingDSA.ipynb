    "def minmax(data):\n",
    "    smallest = [x for x in data if all(x <= y for y in data)][0]\n",
    "    largest = [x for x in data if all(x >= y for y in data)][0]\n",
    "    return (smallest, largest)\n",
    "\n",
    "\n",
