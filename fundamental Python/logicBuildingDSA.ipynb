    "#### 2. Checking 'k' is even or not, if yes return True else False. But, Your Function should use the multiplication, modulo and division Operators."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "29bfa283",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "4 is a Even number: True\n",
      "11 is a Even number: False\n"
     ]
    }
   ],
   "source": [
    "def is_even(k):\n",
    "  # Using Bitwise '&' Operator, if number is even then '&' operator return 0 else it returns 1.\n",
    "  return ( True if (k & 1 == 0) else False ) \n",
    "print(\"4 is a Even number:\",is_even(4))\n",
    "print(\"11 is a Even number:\",is_even(11))"
   ]
  },
