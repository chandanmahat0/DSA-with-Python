       "tuple"
      ]
     },
     "execution_count": 14,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "def minmax(data):\n",
    "  smallest = data[0]\n",
    "  largest = data[0]\n",
    "  for value in data:\n",
    "    if value < smallest:\n",
    "      smallest = value\n",
    "    if value > largest:\n",
    "      largest = value\n",
    "  return (smallest, largest)\n",
    "\n",
    "data = (1,2,3,4,5,6)\n",
    "print(minmax(data))\n",
    "type(minmax(data)) # Type of Output i.e. Tuple."
