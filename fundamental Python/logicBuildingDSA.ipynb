    "def is_multiple(n, m):\n",
    "  for i in range(1,11):\n",
    "    return (True if (n % m == 0) else False) # (n % m == 0)? True: Fale;\n",
    "  \n",
    "n = 78\n",
    "m = 4\n",
    "print(is_multiple(n, m))"
   ]
